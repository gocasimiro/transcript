#!/usr/bin/env bash
# transcript — transcreve áudios usando Parakeet MLX
# Uso: transcript <arquivo|url> [arquivo2|url2 ...] [opções]
#
# Opções:
#   --out <dir>          diretório de saída (padrão: mesmo do áudio / atual para URLs)
#   --model <repo>       modelo HuggingFace (padrão: mlx-community/parakeet-tdt-0.6b-v3)
#   --decoding <método>  greedy ou beam (padrão: greedy)
#   --beam-size <n>      tamanho do beam quando --decoding beam (padrão: 5)
#   --chunk <segundos>   duração de cada chunk em segundos (padrão: 120, 0=desativado)
#   --overlap <segundos> sobreposição entre chunks em segundos (padrão: 15)
#   --local-attention    usa atenção local para áudios longos (>24 min recomendado)
#   --help

set -euo pipefail

export PATH="$HOME/.local/bin:/opt/homebrew/bin:$PATH"

OUT_DIR=""
FILES=()
MODEL=""
DECODING=""
BEAM_SIZE=""
CHUNK_DURATION=""
OVERLAP_DURATION=""
LOCAL_ATTENTION=0

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --out)             OUT_DIR="$2"; shift 2 ;;
    --model)           MODEL="$2"; shift 2 ;;
    --decoding)        DECODING="$2"; shift 2 ;;
    --beam-size)       BEAM_SIZE="$2"; shift 2 ;;
    --chunk)           CHUNK_DURATION="$2"; shift 2 ;;
    --overlap)         OVERLAP_DURATION="$2"; shift 2 ;;
    --local-attention) LOCAL_ATTENTION=1; shift ;;
    --help|-h)
      sed -n '2,15p' "$0" | sed 's/^# //'
      exit 0
      ;;
    -*) echo "Opção desconhecida: $1" >&2; exit 1 ;;
    *)  FILES+=("$1"); shift ;;
  esac
done

if [[ ${#FILES[@]} -eq 0 ]]; then
  echo "Uso: transcript <arquivo|url> [arquivo2|url2 ...] [--out <dir>]" >&2
  exit 1
fi

# Validações
if [[ -n "$DECODING" ]]; then
  case "$DECODING" in
    greedy|beam) ;;
    *) echo "Erro: --decoding deve ser 'greedy' ou 'beam'" >&2; exit 1 ;;
  esac
fi

if [[ -n "$BEAM_SIZE" ]]; then
  if ! [[ "$BEAM_SIZE" =~ ^[1-9][0-9]*$ ]]; then
    echo "Erro: --beam-size deve ser um inteiro positivo" >&2; exit 1
  fi
  if [[ "$DECODING" != "beam" ]]; then
    echo "Aviso: --beam-size só tem efeito com --decoding beam" >&2
  fi
fi

# Monta flags extras para o parakeet-mlx
# Padrão: v3 (multilíngue — detecta idioma automaticamente, incluindo português)
EXTRA_FLAGS=(--model "${MODEL:-mlx-community/parakeet-tdt-0.6b-v3}")
[[ -n "$DECODING" ]]        && EXTRA_FLAGS+=(--decoding "$DECODING")
[[ -n "$BEAM_SIZE" ]]       && EXTRA_FLAGS+=(--beam-size "$BEAM_SIZE")
# --chunk 0 = desativado: não repassa a flag
[[ -n "$CHUNK_DURATION" && "$CHUNK_DURATION" != "0" ]] && EXTRA_FLAGS+=(--chunk-duration "$CHUNK_DURATION")
[[ -n "$OVERLAP_DURATION" ]] && EXTRA_FLAGS+=(--overlap-duration "$OVERLAP_DURATION")
[[ "$LOCAL_ATTENTION" -eq 1 ]] && EXTRA_FLAGS+=(--local-attention)

# Diretório temporário único para todos os downloads da execução
TMP_DIR=""
cleanup() { [[ -n "$TMP_DIR" ]] && rm -rf "$TMP_DIR"; }
trap cleanup EXIT

is_url() { [[ "$1" =~ ^https?:// ]]; }

download_audio() {
  local url="$1"
  # Cria TMP_DIR uma única vez para toda a execução
  [[ -z "$TMP_DIR" ]] && TMP_DIR="$(mktemp -d)"

  # Nome fixo e previsível; yt-dlp adiciona a extensão
  local out_template="$TMP_DIR/audio_$(date +%s%N)"

  echo "Baixando áudio: $url" >&2
  yt-dlp \
    --extract-audio \
    --audio-format wav \
    --output "${out_template}.%(ext)s" \
    --no-playlist \
    "$url"

  # Localiza o arquivo gerado com glob seguro (sem ls)
  local -a wavfiles=("${out_template}"*.wav)
  if [[ ${#wavfiles[@]} -eq 0 || ! -f "${wavfiles[0]}" ]]; then
    echo "Erro: yt-dlp não gerou arquivo de áudio." >&2
    return 1
  fi
  echo "${wavfiles[0]}"   # único stdout: o caminho do arquivo
}

for INPUT in "${FILES[@]}"; do
  SOURCE_URL=""
  AUDIO_FILE=""

  # Resolve URL para arquivo local temporário
  if is_url "$INPUT"; then
    if ! command -v yt-dlp &>/dev/null; then
      echo "Erro: yt-dlp não encontrado. Instale com: brew install yt-dlp" >&2
      continue
    fi
    SOURCE_URL="$INPUT"
    AUDIO_FILE="$(download_audio "$INPUT")" || continue
  else
    AUDIO_FILE="$INPUT"
  fi

  if [[ ! -f "$AUDIO_FILE" ]]; then
    echo "Arquivo não encontrado: $AUDIO_FILE" >&2
    continue
  fi

  ABS_FILE="$(cd "$(dirname "$AUDIO_FILE")" && pwd)/$(basename "$AUDIO_FILE")"
  # URLs sem --out: salva no diretório atual (arquivo local: junto ao arquivo)
  if [[ -n "$OUT_DIR" ]]; then
    DIR="$OUT_DIR"
  elif [[ -n "$SOURCE_URL" ]]; then
    DIR="$(pwd)"
  else
    DIR="$(dirname "$ABS_FILE")"
  fi
  BASENAME="$(basename "${AUDIO_FILE%.*}")"
  TXT_FILE="$DIR/$BASENAME.txt"
  MD_FILE="$DIR/$BASENAME.md"

  # Duração do áudio
  DURATION=$(ffprobe -v error -show_entries format=duration \
    -of default=noprint_wrappers=1:nokey=1 "$ABS_FILE" 2>/dev/null \
    | awk '{printf "%d:%02d", $1/60, $1%60}')

  echo "Transcrevendo: $BASENAME"
  parakeet-mlx "$ABS_FILE" \
    --output-dir "$DIR" \
    --output-format txt \
    "${EXTRA_FLAGS[@]}"

  if [[ ! -f "$TXT_FILE" ]]; then
    echo "Erro: arquivo de saída não gerado." >&2
    continue
  fi

  TRANSCRIPTION=$(cat "$TXT_FILE")
  DATE=$(date +"%Y-%m-%d")
  SOURCE="${SOURCE_URL:-$ABS_FILE}"

  # Gera .md com front matter
  cat > "$MD_FILE" <<MDEOF
---
title: "$BASENAME"
date: $DATE
source: "$SOURCE"
duration: "$DURATION"
---

$TRANSCRIPTION
MDEOF

  rm "$TXT_FILE"

  echo "Salvo em: $MD_FILE"
  echo "---"
  cat "$MD_FILE"
done
